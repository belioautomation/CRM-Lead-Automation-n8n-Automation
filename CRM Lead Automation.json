        "jsCode": "const cleaned = $json.output.replace(/\\\\\\$/g, '$');\n\nconst ai = JSON.parse(cleaned);\n\nreturn [{\n  json: {\n    ...$('Edit Fields').first().json,\n    lead_score: ai.lead_score,\n    priority: ai.priority,\n    industry: ai.industry,\n    summary: ai.summary,\n    next_action: ai.next_action,\n    confidence: ai.confidence\n  }\n}];"
