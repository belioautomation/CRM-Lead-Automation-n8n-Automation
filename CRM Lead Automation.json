    {
      "parameters": {
        "promptType": "define",
        "text": "=Customer Information\n\nName:\n{{$json.name}}\n\nCompany:\n{{$json.company}}\n\nJob Title:\n{{$json.jobTitle}}\n\nEmployees:\n{{$json.employees}}\n\nBudget:\n{{$json.budget}}\n\nInquiry:\n{{$json.message}}",
        "options": {
          "systemMessage": "=You are an experienced CRM lead qualification specialist.\n\nYour task is to analyze business inquiries and score each lead.\n\nEvaluate:\n\nLead Score (0-100)\n\nPriority\n\nIndustry\n\nSummary\n\nRecommended Next Action\n\nConfidence\n\nScoring Guidelines\n\n90-100\nLarge company with high budget and clear business need.\n\n70-89\nMedium company with good budget.\n\n50-69\nSmall business with moderate interest.\n\nBelow 50\nLow-value lead.\n\nReturn STRICT JSON only.\n\nThe property names MUST be exactly:\n\n{\n  \"lead_score\": number,\n  \"priority\": string,\n  \"industry\": string,\n  \"summary\": string,\n  \"next_action\": string,\n  \"confidence\": number\n}\n\n\nEvery string must be valid JSON.\n\nNever output \\$.\n\nUse $ instead.\n\nNo markdown.\n\nNo explanations."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
